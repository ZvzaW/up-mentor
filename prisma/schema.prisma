generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id            String          @id(map: "user_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @db.VarChar(100)
  surname       String          @db.VarChar(100)
  email         String          @unique @db.VarChar(100)
  phone         String          @db.VarChar(30)
  password      String
  role          String          @db.VarChar(20)
  notification  notification[]
  refresh_token refresh_token[]
  trainee       trainee?
  trainer       trainer?
}

model trainer {
  id                 String             @id(map: "trainer_pk") @db.Uuid
  work_description   String?
  price_per_training Int?
  is_public          Boolean            @default(true)
  slug               String             @unique
  coaching_request   coaching_request[]
  cooperation        cooperation[]
  exercise           exercise[]
  opinion            opinion[]
  user               user               @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "trainer_user")
  workout_plan       workout_plan[]
  workplace          workplace[]
}

model trainee {
  id               String             @id(map: "trainee_pk") @db.Uuid
  birthdate        DateTime           @db.Date
  slug             String             @unique
  coaching_request coaching_request[]
  cooperation      cooperation[]
  opinion          opinion[]
  plans_library    plans_library[]
  survey_answer    survey_answer[]
  user             user               @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "trainee_user")
}

model coaching_request {
  trainer_id   String    @db.Uuid
  trainee_id   String    @db.Uuid
  workplace_id String    @db.Uuid
  message      String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  status       String    @default("pending") @db.VarChar(10)
  trainee      trainee   @relation(fields: [trainee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coaching_request_client")
  trainer      trainer   @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coaching_request_trainer")
  workplace    workplace @relation(fields: [workplace_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coaching_request_workplace")

  @@id([trainer_id, trainee_id], map: "coaching_request_pk")
}

model cooperation {
  trainer_id   String         @db.Uuid
  trainee_id   String         @db.Uuid
  workplace_id String         @db.Uuid
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  trainer_note String?
  status       String         @default("active") @db.VarChar(10)
  chat_message chat_message[]
  trainee      trainee        @relation(fields: [trainee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cooperation_trainee")
  trainer      trainer        @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cooperation_trainer")
  workplace    workplace      @relation(fields: [workplace_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cooperation_workplace")
  training     training[]

  @@id([trainer_id, trainee_id], map: "cooperation_pk")
}

model chat_message {
  id          String      @id(map: "chat_message_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id  String      @db.Uuid
  trainee_id  String      @db.Uuid
  sender_id   String      @db.Uuid
  content     String      @db.VarChar(2000)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  cooperation cooperation @relation(fields: [trainer_id, trainee_id], references: [trainer_id, trainee_id], onDelete: Cascade, onUpdate: NoAction, map: "chat_message_cooperation")

  @@index([trainer_id, trainee_id, created_at], map: "chat_message_cooperation_created_idx")
}

model workplace {
  id               String             @id(map: "workplace_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id       String             @db.Uuid
  name             String             @db.VarChar(120)
  street           String             @db.VarChar(120)
  building_number  String             @db.VarChar(20)
  flat_number      String?            @db.VarChar(20)
  city             String             @db.VarChar(120)
  coaching_request coaching_request[]
  cooperation      cooperation[]
  trainer          trainer            @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workplace_trainer")
}

model workout_plan {
  id            String          @id(map: "workout_plan_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id    String          @db.Uuid
  name          String          @db.VarChar(255)
  difficulty    String?         @db.VarChar(100)
  description   String?
  plans_library plans_library[]
  section       section[]
  trainer       trainer         @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "workout_plan_trainer")
}

model section {
  id              String         @id(map: "section_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workout_plan_id String         @db.Uuid
  body_part       String?        @db.VarChar(100)
  order           Int
  exercise_set    exercise_set[]
  workout_plan    workout_plan   @relation(fields: [workout_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "section_workout_plan")
}

model exercise_set {
  id           String   @id(map: "exercise_set_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exercise_id  String   @db.Uuid
  section_id   String   @db.Uuid
  series_count Int
  reps_count   Int
  weight       Decimal? @db.Decimal(5, 2)
  order        Int
  exercise     exercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "set_exercise")
  section      section  @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "set_section")
}

model exercise {
  id           String         @id(map: "exercise_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id   String?        @db.Uuid
  name         String         @db.VarChar(255)
  video_url    String?
  body_part    String         @db.VarChar(100)
  trainer      trainer?       @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "exercise_trainer")
  exercise_set exercise_set[]
}

model training {
  id           String      @id(map: "training_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trainer_id   String      @db.Uuid
  trainee_id   String      @db.Uuid
  scheduled_at DateTime    @db.Timestamptz(6)
  duration     Decimal     @db.Decimal(3, 1)
  cooperation  cooperation @relation(fields: [trainer_id, trainee_id], references: [trainer_id, trainee_id], onDelete: NoAction, onUpdate: NoAction, map: "training_cooperation")
}

model opinion {
  trainee_id String   @db.Uuid
  trainer_id String   @db.Uuid
  rate       Int
  comment    String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  trainee    trainee  @relation(fields: [trainee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "opinion_trainee")
  trainer    trainer  @relation(fields: [trainer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "opinion_trainer")

  @@id([trainee_id, trainer_id], map: "opinion_pk")
}

model survey_answer {
  trainee_id      String          @db.Uuid
  question_id     String          @db.Uuid
  answer          String
  survey_question survey_question @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "answer_question")
  trainee         trainee         @relation(fields: [trainee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "answer_trainee")

  @@id([trainee_id, question_id], map: "survey_answer_pk")
}

model survey_question {
  id            String          @id(map: "survey_question_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question      String
  order         Int
  survey_answer survey_answer[]
}

model notification {
  id           String   @id(map: "notification_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  title        String   @db.VarChar(255)
  message      String   @db.VarChar(255)
  redirect_url String?
  type         String   @db.VarChar(30)
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  user         user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notification_user")
}

model refresh_token {
  id         String   @id(map: "refresh_token_pk") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime @db.Timestamptz(6)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model plans_library {
  trainee_id      String       @db.Uuid
  workout_plan_id String       @db.Uuid
  trainee         trainee      @relation(fields: [trainee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plans_library_trainee")
  workout_plan    workout_plan @relation(fields: [workout_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plans_library_workout")

  @@id([trainee_id, workout_plan_id], map: "plans_library_pk")
}
